# Capitalife Terminal - Public Preview / Vercel
NEXT_PUBLIC_APP_MODE=public-preview
NEXT_PUBLIC_RESEARCH_ONLY=true
NEXT_PUBLIC_APP_NAME=Fund Manager Dashboard

# Simple preview access gate
# For a public repo, set the real value in Vercel Environment Variables.
# Do not commit .env.local.
SIMPLE_GATE_PASSWORD=inno
NEXT_PUBLIC_SIMPLE_GATE_PASSWORD=inno

# Cloud preview must not depend on local Brain or Vault paths
CAPITALIFE_BRAIN_PATH=
INVORIA_BRIDGE_ENABLED=false
INVORIA_BRIDGE_MODE=readonly
SENTINEL_DEFAULT_PROVIDER=disabled

# Optional providers - leave empty in public preview unless intentionally configured in Vercel
OPENAI_API_KEY=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
