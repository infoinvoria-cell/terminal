# Local Dashboard
NEXT_PUBLIC_APP_MODE=local
NEXT_PUBLIC_RESEARCH_ONLY=true
NEXT_PUBLIC_APP_NAME=Fund Manager Dashboard
NEXT_PUBLIC_SIMPLE_GATE_PASSWORD=
SIMPLE_GATE_PASSWORD=inno

# Local Brain path - set per machine, never commit real .env
CAPITALIFE_BRAIN_PATH=
INVORIA_DASHBOARD_PATH=
INVORIA_BRIDGE_ENABLED=false
INVORIA_BRIDGE_MODE=readonly

# Sentinel Providers
SENTINEL_PROVIDER_MODE=local
SENTINEL_DEFAULT_PROVIDER=auto
SENTINEL_ALLOW_PAID_API=false
SENTINEL_ALLOW_CUSTOM_API=false
SENTINEL_REQUIRE_LOCAL_FALLBACK=true
SENTINEL_LOCAL_TIMEOUT_MS=30000
SENTINEL_PARTNER_MODE=false
SENTINEL_BRAIN_CONTEXT_ENABLED=true

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=
OLLAMA_THINK=false

# Optional cloud providers - never commit real keys
OPENAI_API_KEY=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Optional custom API - keep disabled unless explicitly needed
CUSTOM_CHAT_API_URL=
CUSTOM_CHAT_API_KEY=
CUSTOM_CHAT_MODEL=
